# Example: Copy this file to .env and fill in your values
# DO NOT commit the actual .env file to version control

JIRA_BASE_URL=https://jira.domain.com
JIRA_PAT=personal_access_token

# Optional: Custom User-Agent header for environments behind oauth2-proxy
# JIRA_USER_AGENT=your_custom_user_agent_here

# Optional safety switch: keep disabled unless you explicitly need permanent issue deletion
# JIRA_ALLOW_ISSUE_DELETE=false
